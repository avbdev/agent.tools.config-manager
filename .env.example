# =============================================================================
# agent.tools.config-manager — Environment Variables
#
# Copy this file to .env.local for local development and fill in real values.
# NEVER commit .env.local or any file with real secrets to version control.
#
# For production (homelab K8s), all secrets are injected via Vault + ESO.
# For Vercel PR previews, set variables in the Vercel project dashboard.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# Runtime connection string — used by the Next.js app at request time.
# In production this points to PgBouncer (port 6432) for connection pooling.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL="postgresql://app_rw:changeme@localhost:5432/config_manager"

# Direct connection string — used ONLY by Prisma Migrate.
# Must point to PostgreSQL directly (port 5432), bypassing PgBouncer,
# because PgBouncer does not support the extended query protocol that
# migrations require.
# In local dev this is identical to DATABASE_URL.
DIRECT_URL="postgresql://app_rw:changeme@localhost:5432/config_manager"


# ─────────────────────────────────────────────────────────────────────────────
# NEXTAUTH v5 / AUTH.JS
# ─────────────────────────────────────────────────────────────────────────────

# Random secret used to sign cookies and CSRF tokens.
# Required in production. Must be at least 32 characters.
# Generate a secure value: openssl rand -hex 32
AUTH_SECRET="replace-with-openssl-rand-hex-32-output"

# The canonical URL of this deployment.
# Used by next-auth to construct redirect URIs and set cookie domain.
# Must match the URL where the app is accessible.
# Examples:
#   Local dev:    http://localhost:3000
#   Homelab:      https://config-manager.lab.avb.dev
#   Vercel PR:    https://<branch>-config-manager.vercel.app  (set automatically by Vercel)
NEXTAUTH_URL="http://localhost:3000"


# ─────────────────────────────────────────────────────────────────────────────
# MICROSOFT ENTRA ID (AZURE AD) OAUTH
# ─────────────────────────────────────────────────────────────────────────────
# Register an app at: https://portal.azure.com → Azure Active Directory → App registrations
#
# Required redirect URIs to add in the Azure portal:
#   http://localhost:3000/api/auth/callback/microsoft-entra-id   (local dev)
#   https://config-manager.lab.avb.dev/api/auth/callback/microsoft-entra-id  (prod)
#
# Required API permission: Microsoft Graph → User.Read (delegated)
# See TASK-141 for the full registration checklist.

# Directory (tenant) ID — found on the app's Overview page in the Azure portal.
AZURE_AD_TENANT_ID="00000000-0000-0000-0000-000000000000"

# Application (client) ID — found on the app's Overview page.
AZURE_AD_CLIENT_ID="00000000-0000-0000-0000-000000000000"

# Client secret value — created under Certificates & secrets → New client secret.
# 12-month expiry recommended. Rotate via Vault before expiry.
AZURE_AD_CLIENT_SECRET="your-client-secret-value"


# ─────────────────────────────────────────────────────────────────────────────
# ENCRYPTION
# ─────────────────────────────────────────────────────────────────────────────

# AES-256-GCM key used to encrypt secret config values before storing them
# in the database. The stored value is never plaintext when isSecret=true.
#
# Requirements:
#   - Must be at least 32 characters (the key is hashed to exactly 32 bytes internally)
#   - Must be stored in Vault in production — never hardcode in a deployed environment
#   - Changing this key makes all existing encrypted values unreadable (key rotation
#     requires re-encrypting every row — see FEAT-138 for the planned rotation flow)
#
# Generate a secure value: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY="replace-with-openssl-rand-hex-32-output"


# ─────────────────────────────────────────────────────────────────────────────
# REDIS  (rate limiting)
# ─────────────────────────────────────────────────────────────────────────────
# Redis is used for the sliding-window rate limiter (src/lib/rate-limit.ts).
# The application will start without Redis, but rate limiting will fail open
# (requests proceed) and a warning will be logged.
#
# Pick ONE of the two connection modes below:

# ── Mode 1: Single instance (local dev, Vercel preview) ──────────────────────
# Standard Redis URL. Used when REDIS_SENTINEL_HOSTS is not set.
# Format: redis://[:<password>@]<host>:<port>[/<db>]
REDIS_URL="redis://localhost:6379"

# ── Mode 2: Redis Sentinel (homelab HA — takes precedence over REDIS_URL) ────
# Comma-separated list of Sentinel host:port pairs.
# The app connects to the Sentinel cluster and resolves the primary automatically.
# Set all three variables together; omitting REDIS_SENTINEL_HOSTS falls back to REDIS_URL.
# REDIS_SENTINEL_HOSTS="10.25.0.31:26379,10.25.0.32:26379,10.25.0.33:26379"
# REDIS_SENTINEL_MASTER="mymaster"
# REDIS_PASSWORD="your-redis-auth-password"


# ─────────────────────────────────────────────────────────────────────────────
# TRUSTED PROXY CIDRs  (IP extraction for rate limiting and audit logs)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of IPv4 CIDRs that are trusted reverse proxies.
# X-Forwarded-For is only honoured when X-Real-IP comes from one of these ranges.
# This prevents external clients from spoofing their IP address.
#
# Defaults to "127.0.0.1/32" (localhost only) when not set.
#
# Homelab example (K8s pod CIDR + ingress controller IP range):
# TRUSTED_PROXY_CIDRS="10.25.0.0/24,10.244.0.0/16,127.0.0.1/32"
#
# Vercel example (Vercel edge network):
# TRUSTED_PROXY_CIDRS="76.76.21.0/24,76.223.126.0/24,127.0.0.1/32"


# ─────────────────────────────────────────────────────────────────────────────
# OPENTELEMETRY  (distributed tracing — optional)
# ─────────────────────────────────────────────────────────────────────────────
# When set, the app exports OTLP traces to the configured collector.
# Omitting these variables disables tracing silently (no startup error).

# Base URL of the OTLP collector. The path /v1/traces is appended automatically.
# Homelab example (Tempo): http://tempo.monitoring.svc.cluster.local:4318
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Service name shown in Grafana / Tempo trace explorer.
# Defaults to "config-manager" when not set.
# OTEL_SERVICE_NAME="config-manager"


# ─────────────────────────────────────────────────────────────────────────────
# APPLICATION METADATA
# ─────────────────────────────────────────────────────────────────────────────

# Semantic version string exposed to the browser via /api/health.
# Set by the CI pipeline from the Git tag (e.g. v0.2.1).
# Defaults to "dev" when not set.
# NEXT_PUBLIC_APP_VERSION="0.1.0"
