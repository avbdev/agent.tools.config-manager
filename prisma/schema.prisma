// Prisma schema v2 — agent.tools.config-manager
// Full enterprise multi-tenant schema with versioning, audit, secrets, certs, tokens.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Identity & Access Management
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // relations
  memberships  OrgMember[]
  sessions     Session[]
  auditLogs    AuditLog[]
  apiTokens    ApiToken[]
  revealLogs   SecretRevealLog[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  elevated     Boolean  @default(false) // re-auth claim for secret reveals
  elevatedAt   DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

enum Role {
  SUPERADMIN
  ADMIN
  EDITOR
  VIEWER
}

// ---------------------------------------------------------------------------
// Organization / Project / Environment hierarchy
// ---------------------------------------------------------------------------

model Organization {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members      OrgMember[]
  projects     Project[]
  apiTokens    ApiToken[]
  auditLogs    AuditLog[]
}

model OrgMember {
  id     String  @id @default(cuid())
  orgId  String
  userId String
  role   OrgRole @default(VIEWER)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
}

enum OrgRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

model Project {
  id          String   @id @default(cuid())
  orgId       String
  slug        String
  name        String
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  environments Environment[]
  configItems  ConfigItem[]
  secrets      Secret[]
  certificates Certificate[]

  @@unique([orgId, slug])
  @@index([orgId])
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  slug      String   // e.g. "dev" | "staging" | "production"
  name      String
  createdAt DateTime @default(now())

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  configItems ConfigItem[]
  secrets     Secret[]

  @@unique([projectId, slug])
  @@index([projectId])
}

// ---------------------------------------------------------------------------
// Config Items (typed key-value store with versioning)
// ---------------------------------------------------------------------------

model ConfigItem {
  id          String      @id @default(cuid())
  projectId   String
  envId       String
  key         String
  valueType   ValueType   @default(STRING)
  valuePlain  String?     // non-secret value stored in plaintext
  isSecret    Boolean     @default(false)
  description String      @default("")
  tags        String[]    @default([])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String?

  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment      @relation(fields: [envId], references: [id], onDelete: Cascade)
  versions    ConfigVersion[]

  @@unique([projectId, envId, key])
  @@index([projectId, envId])
  @@index([key])
}

model ConfigVersion {
  id           String   @id @default(cuid())
  configItemId String
  version      Int
  valueCipher  String   // always encrypted snapshot (even for non-secrets, for consistency)
  isSecret     Boolean
  valueType    ValueType
  description  String   @default("")
  tags         String[] @default([])
  createdAt    DateTime @default(now())
  createdById  String?

  configItem ConfigItem @relation(fields: [configItemId], references: [id], onDelete: Cascade)

  @@unique([configItemId, version])
  @@index([configItemId])
}

enum ValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  URL
  SECRET_REF // reference to a Secret by id
}

// ---------------------------------------------------------------------------
// Secrets Vault (encrypted at rest, masked in all responses)
// ---------------------------------------------------------------------------

model Secret {
  id          String    @id @default(cuid())
  projectId   String
  envId       String
  name        String    // human-readable label
  key         String    // the variable key (e.g. "STRIPE_SECRET_KEY")
  valueCipher String    // AES-GCM encrypted blob
  description String    @default("")
  tags        String[]  @default([])
  rotatedAt   DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment       @relation(fields: [envId], references: [id], onDelete: Cascade)
  revealLogs  SecretRevealLog[]

  @@unique([projectId, envId, key])
  @@index([projectId, envId])
}

/// Immutable audit trail for every secret reveal event.
model SecretRevealLog {
  id        String   @id @default(cuid())
  secretId  String
  actorId   String
  ipAddress String   @default("")
  userAgent String   @default("")
  createdAt DateTime @default(now())

  secret Secret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([secretId])
  @@index([actorId])
}

// ---------------------------------------------------------------------------
// Certificates (PEM storage + expiry + rotation tracking)
// ---------------------------------------------------------------------------

model Certificate {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  domain      String
  pemCipher   String    // AES-GCM encrypted PEM chain
  keysCipher  String    // AES-GCM encrypted private key
  fingerprint String    // SHA-256 fingerprint of public cert (for de-dup)
  issuer      String    @default("")
  subject     String    @default("")
  expiresAt   DateTime
  issuedAt    DateTime
  autoRotate  Boolean   @default(false)
  rotatedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// API Tokens (scoped, hashed, revokable)
// ---------------------------------------------------------------------------

model ApiToken {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  tokenHash   String    @unique // SHA-256 of the raw token; raw is shown once at creation
  prefix      String    // first 8 chars for UI identification (e.g. "cm_abc12…")
  scopes      String[]  @default([]) // e.g. ["configs:read", "secrets:read"]
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  createdById String?

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([tokenHash])
}

// ---------------------------------------------------------------------------
// Audit Log (immutable — no UPDATE/DELETE enforced via Prisma middleware)
// ---------------------------------------------------------------------------

model AuditLog {
  id           String   @id @default(cuid())
  orgId        String?
  actorId      String
  actorEmail   String   // denormalized snapshot — actor may be deleted
  action       String   // e.g. "secret.reveal", "config.create", "cert.rotate"
  resource     String   // e.g. "secret:clxyz123", "config:clxyz456"
  resourceType String   // e.g. "Secret", "ConfigItem", "Certificate"
  diff         String   @default("") // JSON diff snapshot (no plaintext secrets)
  ipAddress    String   @default("")
  userAgent    String   @default("")
  createdAt    DateTime @default(now())

  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)
  actor User          @relation(fields: [actorId], references: [id], onDelete: Restrict)

  @@index([orgId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([resource])
  @@index([action])
}

// ---------------------------------------------------------------------------
// Rate Limiting (sliding window, per-key)
// ---------------------------------------------------------------------------

model RateLimit {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([key, windowStart])
  @@index([windowStart])
}
